class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        vector<int> result;
        bool a = 0;
        for(int i=0;i<nums.size();i++){
            for(int j=i+1;j<nums.size();j++){
                if(nums[i]+nums[j]==target && a == 0){
                    result.push_back(i);
                    result.push_back(j);
                    a = 1;
                }
            }
            
        }
        return result;
    }
};