class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double as=0,ws=0;
        int n=nums.size();
        for(int i=0;i<k;i++){
            ws+=nums[i];
        }
        as=ws;
        for(int i=k;i<n;i++){
            ws+=nums[i]-nums[i-k];
            as=max(as,ws);
        }
        return as/k;
    }
};