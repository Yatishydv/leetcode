class Solution {
public:
    int findNumbers(vector<int>& nums) {
        
        int count2=0;
        for(int i=0;i<nums.size();i++){
            int count1=0;
            while(nums[i]>0){
                nums[i]%10;
                nums[i]=nums[i]/10;
                count1+=1;
            }
            if(count1%2==0){
                count2++;
            }
        }
        return count2;
    }
};